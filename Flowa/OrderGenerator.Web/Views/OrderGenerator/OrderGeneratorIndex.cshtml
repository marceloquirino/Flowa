@using OrderGenerator.Web.Models.Enums
@model OrderDto

@{
    ViewData["Title"] = "GenerateOrder";
}

<form asp-action="GenerateOrder" method="post">
    <br />
    <div class="container border p-3">
        <h1 class="text-white text-center">Gerar Ordem</h1>
        <hr />
        <div class="row">
            <div class="col-12">
                <div class="row">
                    <div class="col-2">
                        <label class="control-label pt-2" style="font-size:20px;">Símbolo</label>
                        <br />
                        <select asp-for="Symbol" class="form-select" asp-items="Html.GetEnumSelectList<Symbol>()">
                        </select>
                    </div>

                    <div class="col-2">
                        <label class="control-label pt-2" style="font-size:20px;">Ordem</label>
                        <br />
                        <select asp-for="Side" class="form-select" asp-items="Html.GetEnumSelectList<Side>()">
                        </select>
                    </div>

                    <div class="col-2">
                        <label class="control-label pt-2" style="font-size:20px;">Preço</label>
                        <br />
                        <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" max="999.99" />
                    </div>

                    <div class="col-2">
                        <label class="control-label pt-2" style="font-size:20px;">Quantidade</label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" max="99999" />
                    </div>

                    <div class="col-4">
                        <br />
                        <input type="submit" value="Enviar Ordem" class="btn btn-success form-control" style="margin-top:14px" />
                    </div>
                </div>
            </div>
        </div>
    </div>

</form>